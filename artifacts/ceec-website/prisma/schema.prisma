generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum StatutContenu {
  brouillon
  en_attente
  publie
  rejete
}

model Eglise {
  id           Int           @id @default(autoincrement())
  nom          String        @db.VarChar(255)
  slug         String?       @unique @db.VarChar(50)
  sousDomaine  String?       @unique @map("sous_domaine") @db.VarChar(100)
  statut       String        @default("actif") @db.VarChar(20)
  ville        String        @db.VarChar(100)
  adresse      String?
  pasteur      String?       @db.VarChar(255)
  telephone    String?       @db.VarChar(20)
  email        String?       @db.VarChar(255)
  description  String?
  logoUrl      String?       @map("logo_url")
  photoUrl     String?       @map("photo_url")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @default(now()) @updatedAt @map("updated_at")
  annonces      Annonce[]
  config        EgliseConfig?
  pages         PageEglise[]
  evenements    Evenement[]
  inviteTokens  InviteToken[]
  liveStreams    LiveStream[]
  membres       Membre[]
  userRoles     UserRole[]
  activityLogs  ActivityLog[]

  @@map("paroisses")
}

model EgliseConfig {
  id              Int      @id @default(autoincrement())
  egliseId        Int      @unique @map("eglise_id")
  couleurPrimaire String   @default("#1e3a8a") @map("couleur_primaire") @db.VarChar(20)
  couleurAccent   String   @default("#c59b2e") @map("couleur_accent") @db.VarChar(20)
  faviconUrl      String?  @map("favicon_url")
  cssPersonnalise String?  @map("css_personnalise")
  facebook        String?  @db.VarChar(255)
  youtube         String?  @db.VarChar(255)
  instagram       String?  @db.VarChar(255)
  twitter         String?  @db.VarChar(255)
  whatsapp        String?  @db.VarChar(50)
  siteWeb         String?  @map("site_web") @db.VarChar(255)
  horaires        String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")
  footerLinksJson Json?    @map("footer_links_json")
  navLinksJson    Json?    @map("nav_links_json")
  eglise          Eglise   @relation(fields: [egliseId], references: [id], onDelete: Cascade)

  @@map("eglise_configs")
}

model PageEglise {
  id        Int           @id @default(autoincrement())
  egliseId  Int           @map("eglise_id")
  titre     String        @db.VarChar(255)
  slug      String        @db.VarChar(100)
  type      String        @default("custom") @db.VarChar(30)
  publie    Boolean       @default(false)
  ordre     Int           @default(0)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @default(now()) @updatedAt @map("updated_at")
  eglise    Eglise        @relation(fields: [egliseId], references: [id], onDelete: Cascade)
  sections  SectionPage[]

  @@unique([egliseId, slug])
  @@index([egliseId, publie, ordre])
  @@map("eglise_pages")
}

model SectionPage {
  id        Int        @id @default(autoincrement())
  pageId    Int        @map("page_id")
  type      String     @db.VarChar(50)
  ordre     Int        @default(0)
  config    Json       @default("{}")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @default(now()) @updatedAt @map("updated_at")
  page      PageEglise @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId, ordre])
  @@map("eglise_sections")
}

model LiveStream {
  id          Int       @id @default(autoincrement())
  egliseId    Int       @map("eglise_id")
  titre       String    @db.VarChar(255)
  urlYoutube  String    @map("url_youtube") @db.VarChar(500)
  description String?
  dateStream  DateTime? @map("date_stream")
  estEnDirect Boolean   @default(false) @map("est_en_direct")
  epingle     Boolean   @default(false)
  publie      Boolean   @default(true)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")
  eglise      Eglise    @relation(fields: [egliseId], references: [id], onDelete: Cascade)

  @@index([egliseId, publie, epingle])
  @@map("live_streams")
}

model Membre {
  id                Int       @id @default(autoincrement())
  clerkUserId       String    @map("clerk_user_id") @db.VarChar(255)
  nom               String    @db.VarChar(100)
  prenom            String    @db.VarChar(100)
  email             String    @db.VarChar(255)
  telephone         String?   @db.VarChar(20)
  egliseId          Int?      @map("paroisse_id")
  role              String    @default("fidele") @db.VarChar(20)
  dateAdhesion      DateTime? @map("date_adhesion") @db.Date
  statut            String    @default("actif") @db.VarChar(20)
  suspendedByChurch Boolean   @default(false) @map("suspended_by_church")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at")
  annonces          Annonce[]
  eglise            Eglise?   @relation(fields: [egliseId], references: [id])

  @@unique([clerkUserId, egliseId], name: "membre_clerk_eglise_unique")
  @@index([clerkUserId])
  @@map("membres")
}

model Annonce {
  id               Int       @id @default(autoincrement())
  titre            String    @db.VarChar(255)
  contenu          String
  auteurId         Int?      @map("auteur_id")
  egliseId         Int?      @map("paroisse_id")
  datePublication  DateTime  @default(now()) @map("date_publication")
  dateExpiration   DateTime? @map("date_expiration")
  priorite         String    @default("normale") @db.VarChar(20)
  publie           Boolean   @default(true)
  statutContenu    StatutContenu @default(publie) @map("statut_contenu")
  commentaireRejet String?   @map("commentaire_rejet")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at")
  categorie        String?   @db.VarChar(100)
  imageUrl         String?   @map("image_url")
  auteur           Membre?   @relation(fields: [auteurId], references: [id])
  eglise           Eglise?   @relation(fields: [egliseId], references: [id])

  @@index([egliseId, statutContenu])
  @@map("annonces")
}

model Evenement {
  id               Int       @id @default(autoincrement())
  titre            String    @db.VarChar(255)
  description      String?
  dateDebut        DateTime  @map("date_debut")
  dateFin          DateTime? @map("date_fin")
  lieu             String?   @db.VarChar(255)
  egliseId         Int?      @map("paroisse_id")
  imageUrl         String?   @map("image_url")
  publie           Boolean   @default(true)
  statutContenu    StatutContenu @default(publie) @map("statut_contenu")
  commentaireRejet String?   @map("commentaire_rejet")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at")
  categorie        String?   @db.VarChar(100)
  lienInscription  String?   @map("lien_inscription") @db.VarChar(500)
  eglise           Eglise?   @relation(fields: [egliseId], references: [id])

  @@index([egliseId, statutContenu])
  @@map("evenements")
}

model Permission {
  id          Int              @id @default(autoincrement())
  nom         String           @unique @db.VarChar(100)
  description String?
  createdAt   DateTime         @default(now()) @map("created_at")
  roles       RolePermission[]

  @@map("permissions")
}

model Role {
  id           Int              @id @default(autoincrement())
  nom          String           @unique @db.VarChar(50)
  scope        String           @db.VarChar(20)
  permissions  String[]
  createdAt    DateTime         @default(now()) @map("created_at")
  inviteTokens InviteToken[]
  rolePerms    RolePermission[]
  userRoles    UserRole[]

  @@map("roles")
}

model RolePermission {
  id           Int        @id @default(autoincrement())
  roleId       Int        @map("role_id")
  permissionId Int        @map("permission_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  permission   Permission @relation(fields: [permissionId], references: [id])
  role         Role       @relation(fields: [roleId], references: [id])

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  id          Int      @id @default(autoincrement())
  clerkUserId String   @map("clerk_user_id") @db.VarChar(255)
  egliseId    Int?     @map("eglise_id")
  roleId      Int      @map("role_id")
  createdAt   DateTime @default(now()) @map("created_at")
  eglise      Eglise?  @relation(fields: [egliseId], references: [id])
  role        Role     @relation(fields: [roleId], references: [id])

  @@unique([clerkUserId, roleId, egliseId], name: "user_role_unique")
  @@index([clerkUserId])
  @@index([egliseId])
  @@map("user_roles")
}

model CommunauteConfig {
  id        Int      @id @default(autoincrement())
  cle       String   @unique @db.VarChar(100)
  valeur    String   @db.VarChar(255)
  label     String   @db.VarChar(255)
  icone     String   @default("") @db.VarChar(10)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("communaute_config")
}

model InviteToken {
  id        Int       @id @default(autoincrement())
  token     String    @unique @default(dbgenerated("(gen_random_uuid())::text")) @db.VarChar(255)
  email     String    @db.VarChar(255)
  egliseId  Int?      @map("eglise_id")
  roleId    Int?      @map("role_id")
  usedAt    DateTime? @map("used_at")
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  eglise    Eglise?   @relation(fields: [egliseId], references: [id])
  role      Role?     @relation(fields: [roleId], references: [id])

  @@map("invite_tokens")
}

model ActivityLog {
  id          Int      @id @default(autoincrement())
  acteurId    String   @map("acteur_id") @db.VarChar(255)
  acteurNom   String   @map("acteur_nom") @db.VarChar(255)
  action      String   @db.VarChar(50)
  entiteType  String   @map("entite_type") @db.VarChar(50)
  entiteId    Int?     @map("entite_id")
  entiteLabel String?  @map("entite_label") @db.VarChar(255)
  egliseId    Int?     @map("eglise_id")
  egliseNom   String?  @map("eglise_nom") @db.VarChar(255)
  metadata    Json?    @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  eglise      Eglise?  @relation(fields: [egliseId], references: [id], onDelete: SetNull)

  @@index([egliseId, createdAt(sort: Desc)])
  @@index([acteurId, createdAt(sort: Desc)])
  @@index([entiteType, action])
  @@map("activity_logs")
}
